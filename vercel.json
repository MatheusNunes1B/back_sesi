{
  "version": 2,
  "rewrites": [
    { "source": "/api/auth/login",        "destination": "/api/auth/login.js" },
    { "source": "/api/auth/register",     "destination": "/api/auth/register.js" },
    { "source": "/api/leitura/registrar", "destination": "/api/leitura/registrar.js" },
    { "source": "/api/leitura/progresso", "destination": "/api/leitura/progresso.js" },
    { "source": "/api/ranking",           "destination": "/api/ranking/index.js" },
    { "source": "/(.*)",                  "destination": "/public/$1" }
  ],
  "env": {
    "SUPABASE_URL":               "@supabase_url",
    "SUPABASE_SERVICE_ROLE_KEY":  "@supabase_service_role_key",
    "SUPABASE_ANON_KEY":          "@supabase_anon_key"
  }
}
